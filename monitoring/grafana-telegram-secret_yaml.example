# =============================================================================
# Grafana Telegram Alerting Credentials - Template Example
# =============================================================================
# This is a template file. Copy to grafana-telegram-secret.yaml and fill in.
# Deploy with: kubectl apply -f monitoring/grafana-telegram-secret.yaml
#
# How to get the values:
#   1. Talk to @BotFather in Telegram -> /newbot -> copy the token
#   2. Send any message to your new bot
#   3. Open https://api.telegram.org/bot<TOKEN>/getUpdates
#      
# =============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: grafana-telegram
  namespace: monitoring
type: Opaque
stringData:
  bot-token: "123456789:CHANGE_ME_BOT_TOKEN"
